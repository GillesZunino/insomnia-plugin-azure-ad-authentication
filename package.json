{
  "name": "insomnia-plugin-azure-ad-authentication",
  "version": "1.1.4",
  "license": "MIT",
  "author": {
    "name": "Gilles Zunino",
    "email": "giiles@zunino.dev",
    "url": "https://gilles.zunino.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gilleszunino/insomnia-plugin-azure-ad-authentication"
  },
  "keywords": [
    "authentication",
    "azure",
    "microsoft entra",
    "oauth",
    "insomnia",
    "plugin"
  ],
  "insomnia": {
    "name": "azure-ad-authentication",
    "displayName": "Entra ID Token",
    "description": "Easily retrieve Microsoft Entra ID tokens",
    "images": {
      "icon": "images/microsoft-entra-id.svg",
      "cover": "images/microsoft-entra-id.svg"
    },
    "publisher": {
      "name": "Gilles Zunino"
    },
    
    "unlisted": false
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "images/microsoft-entra-id.svg"
  ],
  "scripts": {
    "build:dev": "npx webpack --config webpack.dev.js",
    "build:prod": "npx webpack --config webpack.prod.js",
    "build:tsc": "npx tsc --build tsconfig.json",
    "build:tsdx": "tsdx build --target node --tsconfig ./tsconfig.json",
    "build": "npm run build:dev",
    "prepublishOnly": "npm run build:prod"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@azure/msal-node": "3.8.4",
    "@azure/msal-node-extensions": "1.5.26",
    "express": "5.2.1",
    "open": "11.0.0",
    "validator": "13.15.26"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.0.3",
    "@types/validator": "13.15.10",
    "eslint-plugin-node": "11.1.0",
    "clean-webpack-plugin": "4.0.0",
    "terser-webpack-plugin": "5.3.16",
    "ts-loader": "9.5.4",
    "tsdx": "0.14.1",
    "typescript": "5.9.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1",
    "webpack-merge": "6.0.1",
    "webpack-node-externals": "3.0.0"
  },
  "peerDependencies": {}
}
